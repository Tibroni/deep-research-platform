# LLM Provider Configuration
LLM_PROVIDER=openai
# LLM Provider Keys (at least one is required)
OPENAI_API_KEY=
GEMINI_API_KEY=

# Search Engines
TAVILY_API_KEY=

# Databases
# Leave blank to fallback to a local SQLite database in the backend directory
# On Render, attach a Postgres database and set DATABASE_URL from the dashboard
DATABASE_URL=postgresql://research_user:research_password@localhost:5432/deep_research_platform

# Redis (For pub/sub and WebSocket message broadcasts)
# Leave blank to use memory-based pub/sub routing
REDIS_URL=redis://localhost:6379/0

# Server Config
HOST=0.0.0.0
PORT=8000
DEBUG=False

# Comma-separated browser origins allowed to call the API (your Vercel URL)
CORS_ORIGINS=http://localhost:3000
