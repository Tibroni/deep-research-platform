# LLM Provider Configuration
LLM_PROVIDER=openai
# LLM Provider Keys (at least one is required)
OPENAI_API_KEY=
GEMINI_API_KEY=

# Search Engines
TAVILY_API_KEY=

# Databases
# Leave blank for SQLite (recommended for demos). Only set this for production persistence.
# DATABASE_URL=

# Redis (For pub/sub and WebSocket message broadcasts)
# Leave blank to use memory-based pub/sub routing
REDIS_URL=redis://localhost:6379/0

# Server Config
HOST=0.0.0.0
PORT=8000
DEBUG=False

# Comma-separated browser origins allowed to call the API (your Vercel URL)
CORS_ORIGINS=http://localhost:3000
